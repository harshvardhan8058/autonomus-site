# Autonomous Agent Service — example environment configuration.
# Copy to `.env` and adjust as needed. Every variable the service reads is listed
# here unconditionally with a safe placeholder and a purpose comment (Req 14.2).
# The service runs with ZERO paid API keys: leave GROQ_API_KEY blank to fall back
# automatically to a local Ollama backend.

# --- LLM backends ---
# Groq free-tier API key. Leave blank to auto-fall back to local Ollama.
GROQ_API_KEY=
# Groq model name (primary backend).
GROQ_MODEL=llama-3.3-70b-versatile
# Local Ollama base URL (secondary / fallback backend).
OLLAMA_BASE_URL=http://localhost:11434
# Ollama model name.
OLLAMA_MODEL=llama3.1
# Max retries per backend before falling back / failing.
LLM_MAX_RETRIES=3
# Per-LLM-call timeout in seconds.
LLM_TIMEOUT_SECONDS=60
# When true, if all LLM backends are unreachable the agent generates deterministic
# templated content instead of failing, so a document is always produced.
LLM_OFFLINE_FALLBACK=true

# --- Server ---
# Server bind host.
HOST=0.0.0.0
# Server port.
PORT=8000

# --- Rate limiting (per client IP, sliding window) ---
# Maximum requests allowed per window per IP.
RATE_LIMIT_MAX=10
# Sliding window size in seconds.
RATE_LIMIT_WINDOW_SECONDS=60

# --- Document generation ---
# Heading theme color as a 6-digit hex (no leading #). Invalid values fall back to the default.
THEME_COLOR=1F4E79
# Cover-page "Prepared by" line.
DOCUMENT_PREPARED_BY=Autonomous Agent Service
# Directory where generated .docx files are written.
DOCUMENT_OUTPUT_DIR=./generated

# --- Observability ---
# Logging verbosity (e.g. DEBUG, INFO, WARNING, ERROR).
LOG_LEVEL=INFO
